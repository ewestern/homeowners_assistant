# Database
# Use the same user/password as TCP: `psql -h localhost -U postgres -d homeowners_assistant`
# (Plain `psql homeowners_assistant` often uses a Unix socket + peer auth, which is not what Prisma uses.)
# For Prisma 7 + local Postgres, the app adds sslmode=disable on loopback if your URL omits sslmode (see src/lib/pg-connection-string.ts).
DATABASE_URL="postgresql://postgres:password@localhost:5432/homeowners_assistant"

# Anthropic
ANTHROPIC_API_KEY="your-anthropic-api-key-here"

# App
NEXT_PUBLIC_APP_URL="http://localhost:3000"
